# Copy this file to:
#   $XDG_CONFIG_HOME/taskforce/taskforce.env
# or, if XDG_CONFIG_HOME is unset:
#   ~/.config/taskforce/taskforce.env

# TASKFORCE_ENV=development
# TASKFORCE_SQLITE_PATH=/home/<yourname>/.local/share/taskforce/taskforce.db
# TASKFORCE_POSTGRES_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# TASKFORCE_POSTGRES_HOST=db.<project-ref>.supabase.co
# TASKFORCE_POSTGRES_USER=postgres  # Optional. Defaults to postgres.
# TASKFORCE_POSTGRES_PASS=<password>
# TASKFORCE_POSTGRES_PORT=5432      # Optional. Defaults to 5432.
# TASKFORCE_POSTGRES_DB=postgres    # Optional. Defaults to postgres.
# TASKFORCE_POSTGRES_SSLMODE=require # Optional. Defaults to require.
# TASKFORCE_POSTGRES_SSL_ROOT_CERT=/home/<yourname>/.config/taskforce/supabase-prod-ca-2021.crt
# TASKFORCE_HOST=127.0.0.1
# TASKFORCE_PORT=9090

# When TASKFORCE_ENV or --env selects a profile, taskforce also loads that
# profile's `env_file` as configured under [[profiles.items]] in config.toml.
