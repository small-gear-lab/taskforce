# Copy this file to:
#   $XDG_CONFIG_HOME/taskforce/config.toml
# or, if XDG_CONFIG_HOME is unset:
#   ~/.config/taskforce/config.toml

[profiles]
# default = "production"

[[profiles.items]]
id = "production"
config = "config.production.toml"
env_file = "production.env"

[[profiles.items]]
id = "development"
config = "config.development.toml"
env_file = "development.env"

# Legacy SQLite path. Prefer [backend].sqlite_path for new configs.
# sqlite_path = "/home/<yourname>/.local/share/taskforce/taskforce.db"

[backend]
kind = "sqlite"
# sqlite_path = "/home/<yourname>/.local/share/taskforce/taskforce.db"
# postgres_url = "postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"
# postgres_ssl_root_cert = "/home/<yourname>/.config/taskforce/supabase-prod-ca-2021.crt"

[server]
# host = "127.0.0.1"
# port = 9090  # Optional. Omit this to let taskforce choose a free port.

[list]
# open_statuses = ["active"]  # Status group accordions that start expanded on the task list page.
